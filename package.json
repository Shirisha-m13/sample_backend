{
  "name": "realtime-feedback-backend",
  "version": "1.0.0",
  "description": "Backend API + WebSocket server for real-time feedback app",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations --envPath .env",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --envPath .env"
  },
  "keywords": [
    "express",
    "socket.io",
    "azure"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.7"
  }
}
